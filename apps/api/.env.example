# =============================================================================
# Nishabdha Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# -----------------------------------------------------------------------------
# Database - Supabase PostgreSQL
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
# Example: postgresql://postgres.abcdefghijklmnop:your-password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate a strong secret (minimum 32 characters)
# You can generate one using: openssl rand -base64 32
# Example: VeryLongRandomSecretKeyMinimum32Characters1234567890
JWT_SECRET=YOUR-SUPER-SECRET-JWT-KEY-MINIMUM-32-CHARACTERS-CHANGE-THIS
JWT_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# CORS - Frontend URLs
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Add your frontend URLs here (customer app and admin dashboard)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# -----------------------------------------------------------------------------
# Redis - Upstash (Mumbai Region - Best for India)
# -----------------------------------------------------------------------------
# Get from: Upstash Console → Your Redis Database → Details
# Upstash provides both REST API and Redis protocol
# For this app, we use Redis protocol (faster, lower latency)
#
# Host format: region-12345.upstash.io
# Example: ap-south-1-12345.upstash.io (Mumbai region)
REDIS_HOST=YOUR-REGION-XXXXX.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=YOUR-UPSTASH-PASSWORD

# -----------------------------------------------------------------------------
# MSG91 - SMS Service (India)
# -----------------------------------------------------------------------------
# Get from: MSG91 Dashboard → API → AuthKey
# Example: 123456ABCDEFGabcdefg123456
MSG91_AUTH_KEY=YOUR-MSG91-AUTHKEY-FROM-DASHBOARD

# Sender ID - Use 6 characters for testing
# For production, register a custom sender ID in MSG91 dashboard
MSG91_SENDER_ID=NISHAB

# Template ID - Create OTP template in MSG91
# Get from: MSG91 Dashboard → Templates → Your OTP Template → Template ID
# Template content should include: ##VAR1## for the OTP code
# Example template: "Your Nishabdha verification code is ##VAR1##. Valid for 10 minutes."
MSG91_TEMPLATE_ID=YOUR-MSG91-TEMPLATE-ID

# -----------------------------------------------------------------------------
# Supabase - Admin Authentication
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Project Settings → API
#
# Project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service Role Key (NOT the anon key!)
# Get from: Supabase Dashboard → Project Settings → API → service_role (secret)
# This key has admin privileges - keep it secure!
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS...
SUPABASE_SERVICE_KEY=YOUR-SUPABASE-SERVICE-ROLE-SECRET-KEY

# Admin Dashboard URL - Where admin users will be redirected after email invite
# Update this to your admin frontend URL
# For local development: http://localhost:3002
# For production: https://admin.yourdomain.com
ADMIN_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# Cashfree Payment Gateway (Optional - for checkout/payments)
# -----------------------------------------------------------------------------
# Get from: Cashfree Dashboard → Developers → API Keys
# For development, you can use sandbox credentials
# For production, use production credentials
#
# App ID (Sandbox or Production)
# Example: 123456abcdef1234567890abcdef
CASHFREE_APP_ID=YOUR-CASHFREE-APP-ID

# Secret Key (Sandbox or Production)
# Example: abcdef1234567890abcdef1234567890abcdef12
CASHFREE_SECRET_KEY=YOUR-CASHFREE-SECRET-KEY

# Environment - Use 'sandbox' for testing, 'production' for live payments
CASHFREE_ENVIRONMENT=sandbox

# Webhook Secret - For verifying webhook signatures
# Get from: Cashfree Dashboard → Developers → Webhooks
# Example: whsec_1234567890abcdef
CASHFREE_WEBHOOK_SECRET=YOUR-CASHFREE-WEBHOOK-SECRET

# Frontend URL - Where users will be redirected after payment
FRONTEND_URL=http://localhost:3000

# API URL - For webhook callbacks
API_URL=http://localhost:3001

# =============================================================================
# QUICK SETUP GUIDE
# =============================================================================
#
# 1. SUPABASE SETUP:
#    - Go to https://supabase.com/dashboard
#    - Create new project or select existing
#    - Get DATABASE_URL from: Settings → Database → Connection String → URI
#    - Get SUPABASE_URL from: Settings → API → Project URL
#    - Get SUPABASE_SERVICE_KEY from: Settings → API → service_role key
#
# 2. RENDER REDIS SETUP:
#    - Go to https://dashboard.render.com
#    - Create new Redis instance (free tier available)
#    - Get connection details from: Connect tab
#    - Copy REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
#
# 3. MSG91 SETUP:
#    - Go to https://msg91.com and sign up
#    - Get AUTH_KEY from: Dashboard → API
#    - Create OTP template: Dashboard → Templates
#    - Template: "Your Nishabdha verification code is ##VAR1##. Valid for 10 minutes."
#    - Get TEMPLATE_ID after approval
#
# 4. JWT SECRET:
#    - Generate strong secret: openssl rand -base64 32
#    - Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# 5. CASHFREE SETUP (OPTIONAL - Required only for payment features):
#    - Go to https://www.cashfree.com/developers
#    - Sign up and get sandbox credentials
#    - Get APP_ID and SECRET_KEY from: Developers → API Keys
#    - Generate WEBHOOK_SECRET from: Developers → Webhooks
#    - Note: If not using payments, the app will work with default test values
#
# =============================================================================
# NEXT STEPS
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace all YOUR-* placeholders
# 3. Run migrations: pnpm db:migrate
# 4. Start server: pnpm dev
# 5. Test: curl http://localhost:3001/health
# =============================================================================
